{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/ui_design_reminder.py" },
          { "type": "command", "command": "py .claude/hooks/rule_schema_reminder.py" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "git config user.name 'Adomas' && git config user.email 'g@cool.lt' && git config core.hooksPath .githooks" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/guard_main_push.py" },
          { "type": "command", "command": "py .claude/hooks/require_main_push.py" },
          { "type": "command", "command": "py .claude/hooks/commit_message_check.py", "timeout": 10, "statusMessage": "commit-message format check" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/version_reminder.py", "timeout": 10, "statusMessage": "version-badge reminder" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "py .claude/hooks/save_reminder.py" }
        ]
      }
    ]
  }
}
